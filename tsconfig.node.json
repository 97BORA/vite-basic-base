{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",

        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "skipLibCheck": true,

        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,

        "noEmit": true,

        "types": ["node"]
    },
    "include": ["vite.config.ts", "vitest.config.ts"]
}
